// Python related settings
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "groupName": "Python",
      "matchPackageNames": ["python"],
    },
    {
      "groupName": "Python Packages",
      "matchCategories": ["python"],
    },
    // Include Python packages with custom definitions
    {
      "groupName": "Python Packages",
      "matchDatasources": ["pypi"]
    },
    // Python Tools
    {
      "groupName": "Python Tools",
      "matchPackageNames": [
        // Ruff related dependencies
        // PyPI package - used in pyproject.toml for easier IDE integration
        "ruff",
        // git hooks
        // https://github.com/astral-sh/ruff-pre-commit
        "astral-sh/ruff-pre-commit",

        // ty
        // PyPI package - no use case but adding just in case
        "ty",
        // git hooks
        // https://github.com/astral-sh/ty-pre-commit
        "astral-sh/ty-pre-commit",

        // uv related dependencies
        // Custom dependency for CI workflows
        "uv",
        // Docker image
        // https://docs.astral.sh/uv/guides/integration/docker/
        "ghcr.io/astral-sh/uv",
        // GitHub Actions layer
        // https://github.com/astral-sh/setup-uv
        "astral-sh/setup-uv",
        // git hooks
        // https://github.com/astral-sh/uv-pre-commit
        "astral-sh/uv-pre-commit",

        // git hooks
        // https://github.com/tox-dev/pyproject-fmt
        "tox-dev/pyproject-fmt",

      ],
    },
  ],
}
